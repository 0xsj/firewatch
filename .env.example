# ============================================================================
# Application Configuration
# ============================================================================

# Application metadata
APP_NAME=hexagonal-go
APP_VERSION=1.0.0
APP_ENVIRONMENT=development  # development, staging, production

# ============================================================================
# HTTP Server Configuration
# ============================================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Timeouts (in seconds)
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_IDLE_TIMEOUT=120
SERVER_SHUTDOWN_TIMEOUT=30

# CORS
SERVER_CORS_ENABLED=true
SERVER_CORS_ORIGINS=*  # comma-separated: http://localhost:3000,https://app.example.com

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5436
DATABASE_NAME=hexagonal_identity
DATABASE_USER=hexagonal
DATABASE_PASSWORD=hexagonal_dev_pass
DATABASE_SSL_MODE=disable  # disable, require, verify-ca, verify-full

# Connection pool
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=300  # seconds (5 minutes)

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6383
REDIS_PASSWORD=
REDIS_DB=0

# Connection pool
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# ============================================================================
# Observability Configuration
# ============================================================================

# Logging
LOG_LEVEL=debug  # debug, info, warn, error
LOG_FORMAT=console  # console, json
LOG_COLORIZE=true
LOG_CALLER=true
LOG_TIMESTAMP=true

# Metrics
METRICS_ENABLED=false
METRICS_PATH=/metrics

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4317
TRACING_SAMPLER=always_on  # always_on, always_off, traceidratio